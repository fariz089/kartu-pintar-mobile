{
  "expo": {
    "name": "Kartu Pintar",
    "slug": "kartu-pintar-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#1a2332"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a2332"
      },
      "package": "com.poltekkad.kartupintar",
      "permissions": [
        "android.permission.NFC",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyD4SIvrI0g_O9nXgl3AkQkdJ927WqbvBXc"
        }
      }
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.poltekkad.kartupintar",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Kartu Pintar membutuhkan akses lokasi untuk melacak kartu",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Kartu Pintar membutuhkan akses lokasi untuk melacak kartu"
      },
      "config": {
        "googleMapsApiKey": "AIzaSyD4SIvrI0g_O9nXgl3AkQkdJ927WqbvBXc"
      }
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Izinkan Kartu Pintar mengakses kamera untuk scan QR Code"
        }
      ],
      [
        "react-native-nfc-manager",
        {
          "nfcPermission": "Izinkan Kartu Pintar membaca NFC untuk identifikasi MiLi Card"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Izinkan Kartu Pintar mengakses lokasi untuk pelacakan kartu"
        }
      ]
    ],
    "owner": "sonta23",
    "extra": {
      "eas": {
        "projectId": "c174f57b-d69c-42dd-afb8-88cccc20ddb6"
      }
    }
  }
}
